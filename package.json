{
  "name": "minimalist-portfolio-json",
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "next/*"
  ],
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "serve": "rm -rf dist && astro build && serve --listen 4321 dist",
    "serve:cloudflared": "cloudflared tunnel --url http://localhost:4321/",
    "serve:public": "concurrently --prefix-colors=auto bun:serve bun:serve:cloudflared",
    "generate:favicons": "bun src/scripts/generate-favicons.ts",
    "postinstall": "astro telemetry disable",
    "next:dev": "vp run --parallel --filter \"./next/*\" dev",
    "next:dev:cc": "concurrently -k -c auto -n aurora,terminal,editorial,monolith \"cd next/aurora && bun run dev\" \"cd next/terminal && bun run dev\" \"cd next/editorial && bun run dev\" \"cd next/monolith && bun run dev\"",
    "next:build": "vp run --filter \"./next/*\" build",
    "next:check": "vp check"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/react": "^5.0.0",
    "@astrojs/tailwind": "^6.0.2",
    "@octokit/rest": "^22.0.1",
    "astro": "6.4.4",
    "download": "^8.0.0",
    "favicons": "^7.2.0",
    "hotkeypad": "1.0.2",
    "nullthrows": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-github-calendar": "^5.0.0",
    "react-icons": "^5.5.0",
    "react-snowfall": "^2.3.0",
    "tailwindcss": "^3.4.18",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/download": "^8.0.5",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "serve": "^14.2.5",
    "vite-plus": "0.1.24"
  },
  "packageManager": "bun@1.3.14"
}