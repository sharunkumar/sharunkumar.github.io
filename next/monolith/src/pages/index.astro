---
import Layout from "@/layouts/Layout.astro";
import { basics, work, education } from "@next/shared/cv";
import { socials, email } from "@next/shared/socials";
import { skillGroups, skillsByGroup } from "@next/shared/skills";
import { getProjects } from "@next/shared/projects";
import { dateRange, getYear, totalExperienceYears } from "@next/shared/utils";
import { LuSun, LuMoon } from "react-icons/lu";

const projects = getProjects();
const years = totalExperienceYears();
const { city, region } = basics.location;

const accents = [
  { bg: "bg-cobalt", text: "text-paper" },
  { bg: "bg-tomato", text: "text-paper" },
  { bg: "bg-sun", text: "text-ink" },
  { bg: "bg-lime", text: "text-ink" },
  { bg: "bg-grape", text: "text-ink" },
];
const badges = [
  { label: `${city}, ${region}`, cls: "bg-sun text-ink -rotate-2" },
  { label: `${years}+ years`, cls: "bg-lime text-ink rotate-2" },
  { label: "Fullstack", cls: "bg-cobalt text-paper rotate-1" },
];
---

<Layout>
  <main class="mx-auto max-w-6xl px-4 py-6 sm:px-6">
    <nav class="flex items-center justify-between gap-3">
      <span class="brut bg-ink px-3 py-2 font-display text-xl font-extrabold text-paper">
        SK*
      </span>
      <div class="flex items-center gap-2">
        <div class="hidden items-center gap-2 sm:flex [&_svg]:size-5">
          {
            socials.slice(0, 4).map((social) => {
              const Icon = social.Icon;
              return (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.network}
                  class="brut-sm press grid h-10 w-10 place-items-center bg-bg"
                >
                  <Icon />
                </a>
              );
            })
          }
        </div>
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          class="brut-sm press grid h-10 w-10 place-items-center bg-bg [&_svg]:size-5"
        >
          <span class="theme-light"><LuMoon /></span>
          <span class="theme-dark"><LuSun /></span>
        </button>
        <a
          href={`mailto:${email}`}
          class="brut press bg-sun px-4 py-2.5 font-display font-extrabold uppercase text-ink"
        >
          Email →
        </a>
      </div>
    </nav>

    <section class="grid grid-cols-1 items-end gap-8 py-10 md:grid-cols-[1.6fr_1fr]">
      <div class="pop-in" style="--d:0s">
        <h1
          class="font-display text-[16vw] font-extrabold uppercase leading-[0.82] md:text-[8.5rem]"
        >
          {basics.name.split(" ")[0]}<br />
          <span
            class="brut mt-2 inline-block -rotate-1 bg-cobalt px-3 text-paper"
          >
            {basics.name.split(" ").slice(1).join(" ")}
          </span>
        </h1>
        <p class="mt-6 max-w-md text-lg font-bold">
          {basics.label} building for web, desktop &amp; mobile.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          {
            badges.map((badge) => (
              <span
                class={`brut-sm px-3 py-1.5 text-sm font-bold uppercase ${badge.cls}`}
              >
                {badge.label}
              </span>
            ))
          }
        </div>
      </div>

      <div class="pop-in flex justify-center md:justify-end" style="--d:.12s">
        <figure class="brut press w-full max-w-xs rotate-2 bg-bg p-2">
          <img
            src={basics.image}
            alt={basics.name}
            width="320"
            height="320"
            class="aspect-square w-full border-2 border-fg object-cover"
          />
          <figcaption
            class="mt-2 bg-ink py-1 text-center font-mono text-xs uppercase tracking-widest text-paper"
          >
            @{socials.find((s) => s.network === "GitHub")?.username}
          </figcaption>
        </figure>
      </div>
    </section>

    <div class="brut bg-bg p-5 text-base font-bold leading-relaxed sm:text-lg">
      {basics.summary}
    </div>

    <section id="experience" class="py-10">
      <h2
        class="brut mb-8 inline-block bg-ink px-4 py-2 text-3xl uppercase text-paper sm:text-4xl"
      >
        Experience
      </h2>
      <div class="flex flex-col gap-6">
        {
          work.map((job, index) => {
            const accent = accents[index % accents.length];
            return (
              <article class="brut press grid grid-cols-1 bg-bg sm:grid-cols-[10rem_1fr]">
                <div
                  class={`flex flex-col justify-center border-b-2 border-fg p-4 sm:border-b-0 sm:border-r-[3px] ${accent.bg} ${accent.text}`}
                >
                  <span class="font-display text-2xl font-extrabold leading-none">
                    {getYear(job.startDate)}
                  </span>
                  <span class="font-mono text-sm">
                    → {job.endDate ? getYear(job.endDate) : "now"}
                  </span>
                </div>
                <div class="p-5">
                  <h3 class="text-2xl uppercase">{job.position}</h3>
                  <p class="mb-2 font-mono text-sm font-bold">
                    {job.url ? (
                      <a
                        href={job.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline decoration-2 underline-offset-2"
                      >
                        {job.name} ↗
                      </a>
                    ) : (
                      <span>{job.name}</span>
                    )}
                    {(job.location || job.location_type) && (
                      <span class="text-fg/60">
                        {"  ·  "}
                        {[job.location, job.location_type]
                          .filter(Boolean)
                          .join(", ")}
                      </span>
                    )}
                  </p>
                  {job.summary && (
                    <p class="max-w-2xl text-sm leading-relaxed">{job.summary}</p>
                  )}
                  {job.skills && job.skills.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {job.skills.map((skill) => (
                        <span class="brut-sm bg-bg px-2 py-0.5 font-mono text-xs font-bold">
                          {skill}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            );
          })
        }
      </div>
    </section>

    <section id="projects" class="py-10">
      <h2
        class="brut mb-8 inline-block bg-cobalt px-4 py-2 text-3xl uppercase text-paper sm:text-4xl"
      >
        Projects
      </h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          projects.map((project, index) => {
            const accent = accents[index % accents.length];
            return (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="brut press flex flex-col bg-bg"
              >
                <div
                  class={`flex items-center justify-between border-b-[3px] border-fg p-4 ${accent.bg} ${accent.text}`}
                >
                  <h3 class="text-xl uppercase">{project.title}</h3>
                  <span class="font-display text-xl font-extrabold">↗</span>
                </div>
                <p class="flex-1 p-4 text-sm leading-relaxed">
                  {project.description}
                </p>
                <div class="flex flex-wrap gap-2 p-4 pt-0">
                  {project.languages.map((lang) => (
                    <span class="brut-sm bg-bg px-2 py-0.5 font-mono text-xs font-bold">
                      {lang}
                    </span>
                  ))}
                </div>
              </a>
            );
          })
        }
      </div>
    </section>

    <section id="skills" class="py-10">
      <h2
        class="brut mb-8 inline-block bg-lime px-4 py-2 text-3xl uppercase text-ink sm:text-4xl"
      >
        Toolkit
      </h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          skillGroups.map((group, index) => (
            <div class="brut bg-bg p-5">
              <h3
                class={`mb-3 inline-block px-2 py-1 text-sm uppercase ${accents[index % accents.length].bg} ${accents[index % accents.length].text}`}
              >
                {group}
              </h3>
              <div class="flex flex-wrap gap-2">
                {skillsByGroup(group).map((skill) => {
                  const Icon = skill.Icon;
                  return (
                    <span class="brut-sm flex items-center gap-1.5 bg-bg px-2.5 py-1 font-mono text-sm font-bold [&_svg]:size-4">
                      <Icon />
                      {skill.name}
                    </span>
                  );
                })}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section id="education" class="py-10">
      <h2
        class="brut mb-8 inline-block bg-grape px-4 py-2 text-3xl uppercase text-ink sm:text-4xl"
      >
        Education
      </h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          education.map((school) => (
            <div class="brut bg-bg p-5">
              <span class="font-mono text-sm font-bold text-fg/60">
                {dateRange(school.startDate, school.endDate)}
              </span>
              <h3 class="mt-1 text-2xl uppercase leading-tight">
                {school.institution}
              </h3>
              <p class="font-mono text-sm">
                {school.studyType} — {school.area}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <footer class="brut my-8 bg-ink p-8 text-paper sm:p-12">
      <h2 class="text-4xl uppercase leading-none sm:text-6xl">
        Let&rsquo;s build<br />
        <span class="text-sun">something loud.</span>
      </h2>
      <a
        href={`mailto:${email}`}
        class="brut press mt-8 inline-block bg-sun px-6 py-3 font-display text-lg font-extrabold uppercase text-ink"
      >
        {email} →
      </a>
      <div class="mt-8 flex flex-wrap gap-2 [&_svg]:size-5">
        {
          socials.map((social) => {
            const Icon = social.Icon;
            return (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.network}
                class="brut-sm press grid h-11 w-11 place-items-center bg-paper text-ink"
              >
                <Icon />
              </a>
            );
          })
        }
      </div>
      <p class="mt-8 font-mono text-xs uppercase tracking-widest text-paper/60">
        Syne · Space Mono · Astro · Tailwind v4 · Vite+ · &copy;{" "}
        {new Date().getFullYear()} {basics.name}
      </p>
    </footer>
  </main>

  <script>
    const toggle = document.getElementById("theme-toggle");
    toggle?.addEventListener("click", () => {
      const root = document.documentElement;
      const isDark = root.getAttribute("data-theme") === "dark";
      if (isDark) {
        root.removeAttribute("data-theme");
        localStorage.setItem("monolith-theme", "light");
      } else {
        root.setAttribute("data-theme", "dark");
        localStorage.setItem("monolith-theme", "dark");
      }
    });
  </script>
</Layout>
